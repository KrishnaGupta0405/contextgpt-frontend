{
	"$schema": "node_modules/wrangler/config-schema.json",
	"main": ".open-next/worker.js",
	"name": "contextgpt-frontend",
	"compatibility_date": "2026-07-23",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			// Self-reference service binding, the service name must match the worker name
			// see https://opennext.js.org/cloudflare/caching
			"binding": "WORKER_SELF_REFERENCE",
			"service": "contextgpt-frontend"
		}
	],
	"r2_buckets": [
		// Use R2 incremental cache
		// See https://opennext.js.org/cloudflare/caching
		{
			"binding": "NEXT_INC_CACHE_R2_BUCKET",
			// Create the bucket before deploying
			// You can change the bucket name if you want
			// See https://developers.cloudflare.com/workers/wrangler/commands/#r2-bucket-create
			"bucket_name": "contextgpt-opennext-cache"
		}
	],
	"images": {
		// Enable image optimization
		// see https://opennext.js.org/cloudflare/howtos/image
		"binding": "IMAGES"
	},
	"routes": [
		{
			"pattern": "contextgpt.co",
			"zone_name": "contextgpt.co",
			"custom_domain": true
		}
	],
	"vars": {
		"FRONTEND_REVALIDATE_SECRET": "change_me_dev_secret",
		"INDEXNOW_KEY": "5b4094baca70ae06f0c41cebe7e5abf9",
		"INDEXNOW_TRIGGER_SECRET": "1ca084f8d669692c85f149d221ccee1afde8c22ba4beb994",
		"NEXT_PUBLIC_BACKEND_API_URL": "https://api.contextgpt.co/api/v1",
		"NEXT_PUBLIC_DATAFAST_SITE_ID": "-",
		"NEXT_PUBLIC_ENV": "production",
		"NEXT_PUBLIC_FREE_TOOL_MAX_MESSAGES": "10",
		"NEXT_PUBLIC_FREE_TOOL_MAX_TOKENS": "1000",
		"NEXT_PUBLIC_GOOGLE_LOGIN_CLIENT_ID": "522317130399-e2ca1d82lpo0807p8jdk6pkcpvkssd74.apps.googleusercontent.com",
		"NEXT_PUBLIC_PADDLE_CLIENT_TOKEN": "test_54cba1eafc346eab85cb225bf0c",
		"NEXT_PUBLIC_PADDLE_ENV": "sandbox",
		"NEXT_PUBLIC_PADDLE_SELLER_ID": "46387",
		"NEXT_PUBLIC_PAYMENT_PROCESSOR": "polar",
		"NEXT_PUBLIC_POLAR_ENV": "production",
		"NEXT_PUBLIC_POSTHOG_HOST": "https://us.i.posthog.com",
		"NEXT_PUBLIC_POSTHOG_KEY": "phc_aYpoHkDrDzmPZlvdpmVzczGgWqdkRL5hVmlGNZGH9Sd",
		"NEXT_PUBLIC_RECAPTCHA_SITE_KEY": "-",
		"NEXT_PUBLIC_SITE_URL": "https://contextgpt.co",
		"NEXT_PUBLIC_SOCKET_URL": "https://api.contextgpt.co"
	}
}